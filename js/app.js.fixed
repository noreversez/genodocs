      <div class="modal-ftr">
        <button class="btn btn-primary"   onclick="useExample('${ex.id}');closeExDetail()">ใช้งาน / �?�?้ไข</button>
        <button class="btn btn-secondary" onclick="editExample('${ex.id}');closeExDetail()">�?�?้ไขชื่อ</button>
        <button class="btn btn-ghost"     onclick="closeExDetail()">ปิด</button>
      </div>
    </div>
  `;
  m.addEventListener('click', e => { if (e.target === m) closeExDetail(); });
  document.body.appendChild(m);
}


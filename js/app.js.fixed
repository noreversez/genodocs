function saveExampleEdit(id) {
  const name    = document.getElementById('editExName')?.value.trim();
  const tag     = document.getElementById('editExTag')?.value.trim();
  const content = document.getElementById('editExContent')?.value.trim();
  if (!name)    { alert('�?รุณาระบุชื่อ'); return; }
  if (!content) { alert('�?รุณาระบุเนื้อหา'); return; }
  storage.saveExample({ id, name, tag, content });
  document.getElementById('editExModal')?.remove();
  renderExamples(document.getElementById('exSearch')?.value || '');
  toast('บันทึ�?�?าร�?�?้ไข�?ล้ว');

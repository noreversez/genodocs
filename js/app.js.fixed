  m.id = 'exDetailModal';
  m.className = 'modal-overlay';
  m.innerHTML = `
    <div class="modal">
      <div class="modal-hdr">
        <h3>${escHtml(ex.name)}</h3>
        <button class="btn btn-sm btn-ghost" onclick="closeExDetail()">✕</button>
      </div>
      <div class="modal-body">
        <div class="preview-doc preview-modal">
          <div class="doc-title">บันทึ�?ประจำวัน</div>
          <hr class="doc-line">
          <pre style="font-family:'TH SarabunPSK', 'TH Sarabun New', 'Sarabun', serif;white-space:pre-wrap;font-size:16pt;line-height:1.6">${escHtml(ex.content || '')}</pre>
        </div>

              <option value="gemini-2.5-flash" ${settings.geminiModel === 'gemini-2.5-flash' || !settings.geminiModel ? 'selected' : ''}>Gemini 2.5 Flash (ใหม่ล่าสุด เร็ว)</option>
              <option value="gemini-1.5-flash" ${settings.geminiModel === 'gemini-1.5-flash' ? 'selected' : ''}>Gemini 1.5 Flash (�?นะนำหา�? 2.5 ล่ม/ไม่ว่าง)</option>
              <option value="gemini-1.5-pro" ${settings.geminiModel === 'gemini-1.5-pro' ? 'selected' : ''}>Gemini 1.5 Pro (ฉลาด�?ต่คิวอาจยาว)</option>
